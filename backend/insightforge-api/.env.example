NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/insightforge-ai
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
EMAIL_VERIFICATION_SECRET=
EMAIL_VERIFICATION_EXPIRES_HOURS=24
