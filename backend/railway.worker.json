{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "insightforge-mongo.Dockerfile"
  },
  "deploy": {
    "startCommand": "mongod --bind_ip_all --dbpath /data/db",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
